{
    "agents": {
        "gemini_cli": {
            "logs_dir": "~/.gemini/sessions",
            "turn_threshold": 5
        },
        "antigravity": {
            "logs_dir": "~/.antigravity/sessions",
            "turn_threshold": 5
        },
        "jetski": {
            "logs_dir": "~/.jetski/sessions",
            "turn_threshold": 5
        },
        "claude_code": {
            "logs_dir": "~/.claude/sessions",
            "turn_threshold": 5
        }
    },
    "db_path": "~/.gemini/dream_metrics.db",
    "state_path": "~/.gemini/dream_state.json",
    "bigquery": {
        "enabled": false,
        "project_id": "your-project-id",
        "dataset_id": "gemini_dreams",
        "table_prefix": "dream_"
    },
    "headless_command": [
        "gemini",
        "run",
        "--headless"
    ]
}
